rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.lower() == "rauf2289@gmail.com" ||
         request.auth.uid == "cWib8iMMrih0ClA8NgLYm5uGpKs2" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isApproved() {
      return isAdmin() || (isEmailVerified() && 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'active'));
    }

    function isTechnician() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', '') == 'master' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('userType', '') == 'programmer'));
    }

    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url == "" || url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    function isValidUser(data) {
      let allowedFields = [
        'uid', 'email', 'displayName', 'photoURL', 'phoneNumber', 
        'role', 'userType', 'status', 'isOnline', 'lastSeen', 
        'banned', 'showLocation', 'location', 'workplaceName', 
        'workplaceAddress', 'shopPhotoURL', 'equipmentPhotoURL', 'updatedAt', 'createdAt'
      ];
      return data.keys().hasOnly(allowedFields) &&
             (!('uid' in data) || data.uid is string) &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('displayName' in data) || isValidString(data.displayName, 0, 100)) &&
             (!('photoURL' in data) || (isValidUrl(data.photoURL) && data.photoURL.size() < 1000)) &&
             (!('phoneNumber' in data) || isValidString(data.phoneNumber, 0, 20)) &&
             (!('role' in data) || data.role in ['admin', 'user']) &&
             (!('userType' in data) || data.userType in ['user', 'master', 'programmer']) &&
             (!('status' in data) || data.status in ['active', 'pending', 'rejected']) &&
             (!('workplaceName' in data) || isValidString(data.workplaceName, 0, 100)) &&
             (!('workplaceAddress' in data) || isValidString(data.workplaceAddress, 0, 200)) &&
             (!('shopPhotoURL' in data) || (isValidUrl(data.shopPhotoURL) && data.shopPhotoURL.size() < 1000)) &&
             (!('equipmentPhotoURL' in data) || (isValidUrl(data.equipmentPhotoURL) && data.equipmentPhotoURL.size() < 1000)) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('lastSeen' in data) || data.lastSeen is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidPublicProfile(data) {
      let allowedFields = ['displayName', 'userType', 'status', 'photoURL', 'phoneNumber', 'uid', 'isOnline', 'lastSeen', 'location', 'showLocation'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['displayName', 'userType', 'status']) &&
             isValidString(data.displayName, 0, 100) &&
             data.userType in ['user', 'master', 'programmer'] &&
             data.status in ['active', 'pending', 'rejected'] &&
             (!('photoURL' in data) || (isValidUrl(data.photoURL) && data.photoURL.size() < 1000)) &&
             (!('phoneNumber' in data) || isValidString(data.phoneNumber, 0, 20));
    }

    function isUnchanged(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    // ===============================================================
    // Collections
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      (
                        (request.resource.data.role == 'user' && 
                         (request.resource.data.userType == 'user' ? request.resource.data.status == 'active' : request.resource.data.status == 'pending')) ||
                        (request.resource.data.role == 'admin' && request.resource.data.email.lower() == "rauf2289@gmail.com")
                      );
      allow update: if isAdmin() || (isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      (request.resource.data.get('role', resource.data.get('role', 'user')) == resource.data.get('role', 'user')) && 
                      (request.resource.data.get('userType', resource.data.get('userType', 'user')) == resource.data.get('userType', 'user') || 
                       resource.data.get('userType', 'user') == 'user') && 
                      (request.resource.data.get('status', resource.data.get('status', 'active')) == resource.data.get('status', 'active') || 
                       ((resource.data.get('status', 'active') == 'active' || resource.data.get('status', 'active') == 'rejected') && request.resource.data.status == 'pending')));
      allow delete: if isAdmin();
    }

    // Public Profiles
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidPublicProfile(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && 
                      isValidPublicProfile(request.resource.data) &&
                      (request.resource.data.userType == resource.data.get('userType', request.resource.data.userType) || 
                       resource.data.get('userType', 'user') == 'user') && 
                      isUnchanged('uid'));
      allow delete: if isAdmin();
    }

    // Posts
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isApproved() && (isTechnician() || isAdmin()) &&
                    request.resource.data.authorUid == request.auth.uid &&
                    isValidString(request.resource.data.title, 1, 150) &&
                    isValidString(request.resource.data.content, 1, 500);
      allow update: if isApproved() && (
        isAdmin() || 
        (isTechnician() && resource.data.authorUid == request.auth.uid &&
         isUnchanged('authorUid') && isUnchanged('createdAt') &&
         (!('title' in request.resource.data) || isValidString(request.resource.data.title, 1, 150)) &&
         (!('content' in request.resource.data) || isValidString(request.resource.data.content, 1, 500))
        ) || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      allow delete: if isApproved() && (resource.data.authorUid == request.auth.uid || isAdmin());

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isApproved() && (isTechnician() || isAdmin()) &&
                      request.resource.data.authorUid == request.auth.uid &&
                      isValidString(request.resource.data.content, 1, 300);
        allow update: if isApproved() && (
          isAdmin() ||
          (resource.data.authorUid == request.auth.uid &&
           isUnchanged('authorUid') && isUnchanged('createdAt') &&
           (!('content' in request.resource.data) || isValidString(request.resource.data.content, 1, 300))) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        );
        allow delete: if isApproved() && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    // Products & Accessories & Repair Guides
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /accessories/{accessoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /repairGuides/{guideId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && 
                    request.resource.data.senderId == request.auth.uid && 
                    request.auth.uid in request.resource.data.chatId.split('_') &&
                    (!('content' in request.resource.data) || isValidString(request.resource.data.content, 0, 500));
      allow update: if isAuthenticated() && resource.data.receiverId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }

    // Chats (Typing status)
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in chatId.split('_');
      allow write: if isAuthenticated() && request.auth.uid in chatId.split('_');
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all' || (isAdmin() && resource.data.userId == 'admin'));
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.resource.data.userId != 'all' && request.resource.data.userId is string)
      );
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid) || 
        (isAdmin()) ||
        (resource.data.userId == 'all' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedBy']))
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Purchase Requests
    match /purchaseRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloaded']) &&
        request.resource.data.downloaded == true
      );
      allow delete: if isAdmin();
    }

    // Banned Users - FIXED PII LEAK
    match /bannedUsers/{email} {
      // Only allow a user to check their own ban status, or admin to read/write
      allow read: if isAuthenticated() && (request.auth.token.email.lower() == email.lower() || isAdmin());
      allow write: if isAdmin();
    }

    // FRP Requests - FIXED VALIDATION & METADATA
    match /frpRequests/{requestId} {
      allow read: if isEmailVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidString(request.resource.data.phoneModel, 1, 100) &&
                    isValidString(request.resource.data.imei, 1, 50);
      allow update: if isAdmin() || (
        isEmailVerified() && 
        resource.data.userId == request.auth.uid && 
        isUnchanged('userId') && isUnchanged('phoneModel') && isUnchanged('imei') &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'paid' &&
        resource.data.status == 'price_set'
      );
      allow delete: if isAdmin();
    }

    // Drive Files (Repair Kit & Software Kit)
    match /driveFiles/{fileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Ads
    match /ads/{adId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated() && (settingId == 'ai_config' || isAdmin());
      allow write: if isAdmin();
    }
  }
}
