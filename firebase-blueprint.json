{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email", "maxLength": 100 },
        "displayName": { "type": "string", "maxLength": 100 },
        "photoURL": { "type": "string", "format": "uri" },
        "phoneNumber": { "type": "string", "maxLength": 20 },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "userType": { "type": "string", "enum": ["user", "master", "programmer"] },
        "status": { "type": "string", "enum": ["active", "pending", "rejected"] },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "banned": { "type": "boolean" },
        "showLocation": { "type": "boolean" },
        "location": { "type": "object" },
        "workplaceName": { "type": "string", "maxLength": 100 },
        "workplaceAddress": { "type": "string", "maxLength": 200 },
        "shopPhotoURL": { "type": "string", "format": "uri" },
        "equipmentPhotoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration date" }
      },
      "required": ["uid", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "Forum post",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string", "maxLength": 100 },
        "title": { "type": "string", "minLength": 1, "maxLength": 150 },
        "content": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "createdAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "maxLength": 50 },
        "likes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["authorUid", "title", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Forum post comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string", "maxLength": 100 },
        "content": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["postId", "authorUid", "content", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Shop product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "isDigital": { "type": "boolean" },
        "downloadUrl": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Accessory": {
      "title": "Accessory",
      "description": "Customer accessory",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "imageUrl", "createdAt"]
    },
    "RepairGuide": {
      "title": "RepairGuide",
      "description": "RF Repair Guide",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "problem": { "type": "string" },
        "solution": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "problem"]
    },
    "FrpRequest": {
      "title": "FrpRequest",
      "description": "FRP Server request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email", "maxLength": 100 },
        "userName": { "type": "string", "maxLength": 100 },
        "phoneModel": { "type": "string", "minLength": 1, "maxLength": 100 },
        "androidVersion": { "type": "string", "maxLength": 20 },
        "imei": { "type": "string", "minLength": 1, "maxLength": 50 },
        "serialNumber": { "type": "string", "maxLength": 50 },
        "status": { "type": "string", "enum": ["pending", "price_set", "paid", "completed", "rejected"] },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "phoneModel", "imei", "status", "createdAt"]
    },
    "PurchaseRequest": {
      "title": "PurchaseRequest",
      "description": "Shop purchase request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email", "maxLength": 100 },
        "userName": { "type": "string", "maxLength": 100 },
        "productId": { "type": "string" },
        "productName": { "type": "string", "minLength": 1, "maxLength": 200 },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "downloaded": { "type": "boolean" }
      },
      "required": ["userId", "productId", "status", "createdAt"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "In-app notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string", "maxLength": 100 },
        "body": { "type": "string", "maxLength": 500 },
        "link": { "type": "string", "maxLength": 200 },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["userId", "title", "body", "createdAt", "read"]
    },
    "DriveFile": {
      "title": "DriveFile",
      "description": "File or folder in the drive",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["folder", "file", "image"] },
        "url": { "type": "string" },
        "parentId": { "type": "string" },
        "kitType": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "storagePath": { "type": "string" }
      },
      "required": ["name", "type", "kitType", "createdAt", "createdBy"]
    },
    "RentableTool": {
      "title": "RentableTool",
      "description": "Software tool available for rent",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "prices": { "type": "object" },
        "category": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "prices"]
    },
    "RentalRequest": {
      "title": "RentalRequest",
      "description": "Request to rent a software tool",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "toolId": { "type": "string" },
        "toolName": { "type": "string" },
        "duration": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "rejected"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "credentials": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "toolId", "duration", "status", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global app settings",
      "type": "object",
      "properties": {
        "geminiApiKey": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "publicProfiles/{userId}": {
      "schema": "User",
      "description": "Public user profiles for location sharing"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Forum posts"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on posts"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Shop products"
    },
    "accessories/{accessoryId}": {
      "schema": "Accessory",
      "description": "Customer accessories"
    },
    "repairGuides/{guideId}": {
      "schema": "RepairGuide",
      "description": "RF repair guides"
    },
    "frpRequests/{requestId}": {
      "schema": "FrpRequest",
      "description": "FRP Server requests"
    },
    "purchaseRequests/{requestId}": {
      "schema": "PurchaseRequest",
      "description": "Shop purchase requests"
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "In-app notifications"
    },
    "driveFiles/{fileId}": {
      "schema": "DriveFile",
      "description": "Files and folders in repair/software kits"
    },
    "rentableTools/{toolId}": {
      "schema": "RentableTool",
      "description": "Software tools available for rent"
    },
    "rentalRequests/{requestId}": {
      "schema": "RentalRequest",
      "description": "Software rental requests"
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Global application settings"
    }
  }
}
